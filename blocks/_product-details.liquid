{%- assign block_settings = block.settings -%}

<div
  id="ProductInformation-{{ section.id }}"
  class="product-details flt-product-details-panel{% if block_settings.sticky_details_desktop %} sticky-content--desktop{% endif %}"
  {{ block.shopify_attributes }}
>
  <div class="flt-pdp__title-wrap">
    <h1 class="flt-pdp__title">{{ closest.product.title }}</h1>
  </div>

  {% content_for 'blocks' %}
</div>

{% stylesheet %}
.flt-product-details-panel {
  display: flex;
  flex-direction: column;
  gap: 20px;
  padding: 0 0 40px;
  width: 100%;
  min-width: 100%;
}

.sticky-content--desktop {
  position: sticky;
  top: calc(var(--header-group-height, 80px) + 20px);
  z-index: var(--layer-flat, 1);
}

.flt-pdp__title {
  /* Changed font from Bebas Neue to Arial (safe sans-serif) */
  font-family: Arial, Helvetica, sans-serif;
  font-size: clamp(28px, 3.5vw, 48px);
  color: #0B2545;
  letter-spacing: 0.03em; /* safe spacing for mobile */
  text-transform: uppercase;
  line-height: 1.2;
  margin: 0;
  display: block;
  width: 100%;
}

/* Mobile adjustments */
@media screen and (max-width: 749px) {
  .flt-pdp__title {
    font-size: clamp(28px, 4vw, 40px);
    letter-spacing: 0.02em; /* slightly tighter spacing for smaller screens */
  }
}

@media screen and (max-width: 989px) {
  .flt-product-details-panel {
    padding: 0 0 32px;
    flex: 1 1 100%;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "FLT Product Details",
  "blocks": [
    { "type": "@theme" },
    { "type": "price" },
    { "type": "variant-picker" },
    { "type": "buy-buttons" },
    { "type": "product-description" },
    { "type": "group" }
  ],
  "settings": [
    {
      "type": "checkbox",
      "id": "sticky_details_desktop",
      "label": "Sticky Details on Desktop",
      "default": true
    }
  ]
}
{% endschema %}