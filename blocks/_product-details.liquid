{%- assign block_settings = block.settings -%}

<div
  id="ProductInformation-{{ section.id }}"
  class="product-details flt-product-details-panel{% if block_settings.sticky_details_desktop %} sticky-content--desktop{% endif %}"
  {{ block.shopify_attributes }}
>
  <div class="flt-pdp__title-wrap">
    <h1 class="flt-pdp__title">{{ closest.product.title }}</h1>
  </div>

  {% content_for 'blocks' %}
</div>

{% stylesheet %}
/* ── Shopify wrapper grid placement (mobile) ──────────────────────────
   Shopify injects a div.shopify-block around block content. On mobile,
   product-information__grid has 3 subgrid columns: [margin][content][margin].
   Without explicit placement, the wrapper auto-places in col 1 (16px margin).
   This forces it into col 2 (the content column). ── */
@media screen and (max-width: 749px) {
  .product-information__grid > .shopify-block:has(.flt-product-details-panel) {
    grid-column: 2 / 3;
  }
}

.flt-product-details-panel {
  display: flex;
  flex-direction: column;
  gap: 20px;
  padding: 0 0 40px;
  width: 100%;
  min-width: 0;
}

.sticky-content--desktop {
  position: sticky;
  top: calc(var(--header-group-height, 80px) + 20px);
  z-index: var(--layer-flat, 1);
}

.flt-pdp__title {
  font-family: var(--head, 'Bebas Neue', sans-serif);
  font-size: clamp(28px, 3.5vw, 48px);
  color: #0B2545;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  line-height: 1.1;
  margin: 0;
  display: block;
  width: 100%;
  white-space: normal;
  word-break: normal;
}

@media screen and (max-width: 989px) {
  .flt-product-details-panel { padding: 0 0 32px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "FLT Product Details",
  "blocks": [
    { "type": "@theme" },
    { "type": "price" },
    { "type": "variant-picker" },
    { "type": "buy-buttons" },
    { "type": "product-description" },
    { "type": "group" }
  ],
  "settings": [
    {
      "type": "checkbox",
      "id": "sticky_details_desktop",
      "label": "Sticky Details on Desktop",
      "default": true
    }
  ]
}
{% endschema %}