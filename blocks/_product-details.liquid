{%- assign block_settings = block.settings -%}

<div class="flt-product-layout">
  
<div class="flt-product-media">
  <div class="product-images-wrapper">
    {% if closest.product.featured_image %}
      <div class="product__media-main">
        <img 
          id="MainProductImage-{{ section.id }}" 
          src="{{ closest.product.featured_image | image_url: width: 800 }}" 
          alt="{{ closest.product.title | escape }}"
          class="main-img-element"
          loading="eager"
        >
      </div>
    {% endif %}

    {% if closest.product.images.size > 1 %}
      <div class="product__media-grid">
        {% for image in closest.product.images %}
          <button 
            type="button"
            class="product__media-item {% if image == closest.product.featured_image %}is-active{% endif %}" 
            data-large-src="{{ image | image_url: width: 800 }}"
            aria-label="View product image {{ forloop.index }}"
            onclick="swapProductImage(this)"
          >
            <img src="{{ image | image_url: width: 150 }}" alt="Thumbnail" loading="lazy">
          </button>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

  <div
    id="ProductInformation-{{ section.id }}"
    class="product-details {% if block_settings.sticky_details_desktop %} sticky-content--desktop{% endif %}"
    style="--product-details-padding-top: {{ block_settings.gap }}px;"
  >
    {% capture children %}
      <div class="view-product-title">
        <h1 class="h2">{{ closest.product.title }}</h1>
      </div>
      {% content_for 'blocks' %}
    {% endcapture %}

    {% render 'group', children: children, settings: block_settings, shopify_attributes: block.shopify_attributes %}
  </div>
</div>

<script>
  function swapProductImage(element, newSrc) {
    // 1. Update the Main Image
    const mainImg = document.getElementById('MainProductImage-{{ section.id }}');
    if(mainImg) mainImg.src = newSrc;

    // 2. Update Active Thumbnail Styling
    const allThumbs = element.parentElement.querySelectorAll('.product__media-item');
    allThumbs.forEach(thumb => thumb.classList.remove('is-active'));
    element.classList.add('is-active');
  }
</script>

{% stylesheet %}
/* 1. Layout Structure: Side-by-Side */
.flt-product-layout {
  display: grid;
  grid-template-columns: 1.2fr 1fr; /* Media takes slightly more room than text */
  gap: 60px;
  align-items: start;
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 40px;
}

/* 2. Media Styles (Left Side) */
.flt-product-media {
  width: 100%;
}

.product__media-main {
  width: 100%;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(0,0,0,0.06);
  margin-bottom: 16px;
  background: #f8f8f8;
}

.product__media-main img {
  width: 100%;
  height: auto;
  display: block;
}

.product__media-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
  gap: 12px;
}

.product__media-item {
  aspect-ratio: 1 / 1;
  border-radius: 8px;
  overflow: hidden;
  border: 2px solid transparent;
  cursor: pointer;
  transition: all 0.2s ease;
}

.product__media-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.product__media-item.is-active {
  border-color: #0B2545;
}

/* 3. Details Styles (Right Side) */
.product-details {
  display: flex;
  flex-direction: column;
}

.sticky-content--desktop {
  position: sticky;
  top: calc(var(--header-group-height, 80px) + 20px);
}

/* 4. Mobile Responsiveness */
@media screen and (max-width: 989px) {
  .flt-product-layout {
    grid-template-columns: 1fr; /* Stack on tablet/mobile */
    gap: 32px;
    padding: 0 20px;
  }
  
  .product__media-grid {
    grid-template-columns: repeat(5, 1fr); /* 5 thumbs across on mobile */
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "FLT Product Details",
  "blocks": [
    { "type": "@theme" },
    { "type": "price" },
    { "type": "variant-picker" },
    { "type": "buy-buttons" },
    { "type": "product-description" },
    { "type": "group" }
  ],
  "settings": [
    { "type": "checkbox", "id": "sticky_details_desktop", "label": "Sticky Details on Desktop", "default": true },
    { "type": "range", "id": "gap", "label": "Top Padding", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 20 }
  ]
}
{% endschema %}