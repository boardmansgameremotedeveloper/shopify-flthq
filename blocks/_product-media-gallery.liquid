{%- assign featured_media = closest.product.selected_or_first_available_variant.featured_media
    | default: closest.product.featured_media -%}

<div class="flt-media-gallery" id="flt-media-gallery-{{ section.id }}" {{ block.shopify_attributes }}>

  {%- comment -%} Main image {%- endcomment -%}
  <div class="flt-media__main" id="MainProductMedia-{{ section.id }}">
    {{ featured_media | image_url: width: 1200 | image_tag:
      id: 'MainProductImage',
      loading: 'eager',
      class: 'flt-media__img',
      widths: '400, 600, 800, 1200',
      alt: featured_media.alt | escape
    }}
  </div>

  {%- comment -%} Thumbnail strip {%- endcomment -%}
  {%- if closest.product.media.size > 1 -%}
    <div class="flt-media__thumbs" role="list">
      {%- for media in closest.product.media -%}
        <button
          type="button"
          class="flt-media__thumb{% if media == featured_media %} is-active{% endif %}"
          data-media-id="{{ media.id }}"
          data-large-src="{{ media | image_url: width: 1200 }}"
          aria-label="{{ 'products.thumbnail_loop' | t: number: forloop.index }}"
          onclick="fltSwapImage(this)"
          role="listitem"
        >
          {{ media.preview_image | image_url: width: 200 | image_tag:
            loading: 'lazy',
            sizes: '80px',
            widths: '80, 160',
            alt: media.alt | escape
          }}
        </button>
      {%- endfor -%}
    </div>
  {%- endif -%}

</div>

<script>
  function fltSwapImage(el) {
    var newSrc = el.dataset.largeSrc;
    var mainImg = document.getElementById('MainProductImage');
    if (mainImg && newSrc) mainImg.src = newSrc;
    var thumbs = el.closest('.flt-media__thumbs');
    if (thumbs) {
      thumbs.querySelectorAll('.flt-media__thumb').forEach(function(t) {
        t.classList.remove('is-active');
      });
    }
    el.classList.add('is-active');
  }
</script>

{% stylesheet %}
.flt-media-gallery {
  display: flex;
  flex-direction: column;
  gap: 16px;
  width: 100%;
}

.flt-media__main {
  width: 100%;
  border-radius: 12px;
  overflow: hidden;
  background: #f8f8f8;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
}

.flt-media__img {
  width: 100%;
  height: auto;
  display: block;
}

.flt-media__thumbs {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(72px, 1fr));
  gap: 10px;
}

.flt-media__thumb {
  aspect-ratio: 1 / 1;
  border-radius: 8px;
  overflow: hidden;
  border: 2px solid transparent;
  cursor: pointer;
  padding: 0;
  background: none;
  transition: border-color 0.2s ease;
}

.flt-media__thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.flt-media__thumb.is-active {
  border-color: #0B2545;
}

.flt-media__thumb:hover:not(.is-active) {
  border-color: #c0c0c0;
}

@media screen and (max-width: 989px) {
  .flt-media__thumbs {
    grid-template-columns: repeat(5, 1fr);
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "FLT Product Media",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "FLT Product Media"
    }
  ]
}
{% endschema %}
