{% comment %}
  snippets/star-rating.liquid
  FLT Hemp Provisions — Star rating display
  Source: frontend/src/components.jsx → Stars
  Usage: {% render 'star-rating', rating: 4.9 %}
{% endcomment %}
{% assign r = rating | default: 0 | round %}
<div style="display:flex;gap:2px;align-items:center;">
  {% for i in (1..5) %}
    {% if i <= r %}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="#D4A017" aria-hidden="true">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
    {% else %}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="#CBD5E1" aria-hidden="true">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
    {% endif %}
  {% endfor %}
  <span style="font-size:12px;color:#64748B;margin-left:6px;font-family:var(--body);">({{ rating }})</span>
</div>
