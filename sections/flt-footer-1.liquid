{% comment %}
  sections/footer.liquid
  FLT Hemp Provisions — Footer
{% endcomment %}

<style>
  .flt-footer {
    padding: 50px 40px 28px;
    background: #070E1A;
    border-top: 1px solid rgba(147,197,253,0.08);
    font-family: var(--body, 'Source Sans 3', sans-serif);
  }
  .flt-footer__inner { max-width: 1300px; margin: 0 auto; }
  .flt-footer__grid {
    display: grid; 
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 36px; 
    margin-bottom: 36px;
  }
  .flt-footer__brand-logo { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
  .flt-footer__brand-name {
    font-family: var(--head, 'Bebas Neue', sans-serif);
    font-size: 22px; color: #93C5FD; letter-spacing: 0.15em;
  }
  .flt-footer__brand-desc {
    font-size: 13px; color: rgba(255,255,255,0.25); line-height: 1.7; max-width: 280px;
  }
  .flt-footer__col-title {
    font-size: 11px; color: #93C5FD;
    letter-spacing: 0.12em; text-transform: uppercase;
    margin-bottom: 14px; font-weight: 700;
  }
  .flt-footer__col-link {
    display: block; font-size: 13px;
    color: rgba(255,255,255,0.2); margin-bottom: 9px;
    text-decoration: none; transition: color 0.2s ease;
    background: none; border: none; padding: 0; text-align: left; cursor: pointer;
    width: 100%;
  }
  .flt-footer__col-link:hover { color: rgba(255,255,255,0.5); }
  .flt-footer__bottom {
    border-top: 1px solid rgba(255,255,255,0.05); padding-top: 20px;
    display: flex; justify-content: space-between;
    align-items: center; flex-wrap: wrap; gap: 14px;
  }
  .flt-footer__copy { font-size: 12px; color: rgba(255,255,255,0.15); }
  .flt-footer__payments { display: flex; gap: 14px; align-items: center; }
  .flt-footer__pay-label { font-size: 11px; color: rgba(255,255,255,0.15); }
  .flt-footer__pay-authnet {
    background: linear-gradient(135deg, #1E3A5F, #2563EB);
    padding: 3px 8px; border-radius: 5px;
    font-size: 9px; color: #fff; font-weight: 800; letter-spacing: 0.04em;
  }
  .flt-footer__pay-card {
    background: rgba(255,255,255,0.05); padding: 3px 7px; border-radius: 4px;
    font-size: 8px; color: rgba(255,255,255,0.3);
    font-weight: 700; letter-spacing: 0.06em;
  }
  @media (max-width: 768px) {
    .flt-footer__grid { grid-template-columns: 1fr 1fr; }
    .flt-footer__brand { grid-column: 1 / -1; }
    .flt-footer { padding: 40px 20px 20px; }
  }
</style>

<footer class="flt-footer">
  <div class="flt-footer__inner">
    <div class="flt-footer__grid">
      
      {% comment %} Brand Column {% endcomment %}
      <div class="flt-footer__brand">
        <div class="flt-footer__brand-logo">
          {% render 'flt-plane-icon-1', size: 30, color: '#93C5FD' %}
          <div class="flt-footer__brand-name">FLT</div>
        </div>
        <p class="flt-footer__brand-desc">{{ section.settings.brand_desc }}</p>
      </div>

      {% comment %} Menu Column 1 {% endcomment %}
      <div class="flt-footer__column">
        <div class="flt-footer__col-title">{{ section.settings.title_1 }}</div>
        {%- assign menu_1 = section.settings.menu_1 -%}
        {%- if menu_1 != blank -%}
          {%- for link in menu_1.links -%}
            {%- render 'flt-footer-link', link: link -%}
          {%- endfor -%}
        {%- endif -%}
      </div>

      {% comment %} Menu Column 2 {% endcomment %}
      <div class="flt-footer__column">
        <div class="flt-footer__col-title">{{ section.settings.title_2 }}</div>
        {%- assign menu_2 = section.settings.menu_2 -%}
        {%- if menu_2 != blank -%}
          {%- for link in menu_2.links -%}
            {%- render 'flt-footer-link', link: link -%}
          {%- endfor -%}
        {%- endif -%}
      </div>

      {% comment %} Menu Column 3 {% endcomment %}
      <div class="flt-footer__column">
        <div class="flt-footer__col-title">{{ section.settings.title_3 }}</div>
        {%- assign menu_3 = section.settings.menu_3 -%}
        {%- if menu_3 != blank -%}
          {%- for link in menu_3.links -%}
            {%- render 'flt-footer-link', link: link -%}
          {%- endfor -%}
        {%- endif -%}
      </div>

    </div>

    <div class="flt-footer__bottom">
      <div class="flt-footer__copy">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved. Must be 21+.
      </div>
      <div class="flt-footer__payments">
        <span class="flt-footer__pay-label">Secured by</span>
        <span class="flt-footer__pay-authnet">AUTHORIZE.NET</span>
        <span class="flt-footer__pay-card">VISA</span>
        <span class="flt-footer__pay-card">MC</span>
        <span class="flt-footer__pay-card">AMEX</span>
      </div>
    </div>
  </div>
</footer>

{%- comment -%} 
  To avoid repeating the anchor logic 3 times, we use a simple inline loop check. 
  Note: I've included the logic directly here to keep it in one file.
{%- endcomment -%}

<script>
  (function() {
    var footer = document.querySelector('.flt-footer');
    if (!footer) return;
    footer.querySelectorAll('[data-anchor]').forEach(function(el) {
      el.addEventListener('click', function(e) {
        var target = document.getElementById(this.dataset.anchor);
        if(target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth' });
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "brand_desc",
      "label": "Brand description",
      "default": "Premium hemp-derived beverages and wellness gummies. Clean ingredients. Rapid absorption. Elevate your flight."
    },
    { "type": "header", "content": "Column 1" },
    { "type": "text", "id": "title_1", "label": "Heading 1", "default": "Shop" },
    { "type": "link_list", "id": "menu_1", "label": "Menu 1" },
    { "type": "header", "content": "Column 2" },
    { "type": "text", "id": "title_2", "label": "Heading 2", "default": "Company" },
    { "type": "link_list", "id": "menu_2", "label": "Menu 2" },
    { "type": "header", "content": "Column 3" },
    { "type": "text", "id": "title_3", "label": "Heading 3", "default": "Support" },
    { "type": "link_list", "id": "menu_3", "label": "Menu 3" }
  ],
  "presets": [
    {
      "name": "FLT Footer",
      "settings": {
        "menu_1": "footer-shop",
        "menu_2": "footer-company",
        "menu_3": "footer-support"
      }
    }
  ]
}
{% endschema %}