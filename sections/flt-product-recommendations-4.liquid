{%- comment -%}
  sections/flt-product-recommendations-4.liquid
  FLT Hemp Provisions — Same-Collection Related Products
  Finds up to 4 products from the current product's primary collection.
  Renders nothing when no related products exist.
{%- endcomment -%}

{%- comment -%} Find the first real collection this product belongs to (skip 'all' / 'frontpage'). {%- endcomment -%}
{%- assign flt_primary_col = nil -%}
{%- for col in product.collections -%}
  {%- if flt_primary_col == nil and col.handle != 'all' and col.handle != 'frontpage' -%}
    {%- assign flt_primary_col = col -%}
  {%- endif -%}
{%- endfor -%}

{%- comment -%} Pre-count related products so we can hide the section entirely when empty. {%- endcomment -%}
{%- assign flt_rel_count = 0 -%}
{%- if flt_primary_col -%}
  {%- for p in flt_primary_col.products -%}
    {%- if p.id != product.id -%}
      {%- assign flt_rel_count = flt_rel_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- if flt_rel_count > 0 -%}

<style>
  .flt-related {
    padding: 60px 40px 80px;
    background: #fff;
  }
  .flt-related__inner {
    max-width: 1300px;
    margin: 0 auto;
  }
  .flt-related__heading {
    font-family: var(--head, 'Bebas Neue', sans-serif);
    font-size: clamp(28px, 3vw, 40px);
    color: #0B2545;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 32px 0;
    line-height: 1;
  }
  .flt-related__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    align-items: start;
  }
  @media (max-width: 768px) {
    .flt-related {
      padding: 48px 20px 60px;
    }
    .flt-related__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
  }
</style>

<section class="flt-related" {{ section.shopify_attributes }}>
  <div class="flt-related__inner">
    <h2 class="flt-related__heading">You May Also Like</h2>
    <div class="flt-related__grid">
      {%- assign flt_rendered = 0 -%}
      {%- for p in flt_primary_col.products -%}
        {%- if p.id != product.id and flt_rendered < 4 -%}
          {% render 'flt-product-card-1', product: p %}
          {%- assign flt_rendered = flt_rendered | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{%- endif -%}

{% schema %}
{
  "name": "FLT Related Products",
  "tag": "div",
  "settings": [],
  "presets": [
    {
      "name": "FLT Related Products"
    }
  ]
}
{% endschema %}
