{% comment %}
  sections/flt-product-recommendations-1.liquid
  Updated to include FLT Scroll Reveal and matching grid layout.
{% endcomment %}

<script src="{{ 'product-recommendations.js' | asset_url }}" defer="defer"></script>

<style>
  .flt-recs {
    padding: 80px 40px; /* Increased padding to match homepage feel */
    background: #fff;
    position: relative;
  }

  .flt-recs__inner {
    max-width: 1300px;
    margin: 0 auto;
  }

  .flt-recs__heading-wrap {
    text-align: center; /* Centered to match homepage style */
    margin-bottom: 48px;
  }

  .flt-recs__eyebrow {
    font-family: var(--body);
    font-size: 13px;
    color: #64748B;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    margin-bottom: 12px;
    font-weight: 600;
  }

  .flt-recs__title {
    font-family: var(--head);
    font-size: clamp(32px, 4vw, 48px);
    color: #0B2545;
    margin: 0;
    line-height: 1;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .flt-recs__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 28px;
  }

  /* Scroll reveal support for the recommendations */
  .flt-recs .flt-reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .flt-recs .flt-reveal.in-view {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .flt-recs { padding: 60px 20px; }
    .flt-recs__grid { 
      grid-template-columns: 1fr; /* Single column on mobile like homepage */
      gap: 24px;
    }
  }
</style>

<product-recommendations
  id="flt-product-recommendations-{{ section.id }}"
  class="flt-recs-component"
  data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit=4"
>
  <pre>{{ recommendations | json }}</pre>


  {% if recommendations.performed and recommendations.products_count > 0 %}
    <section class="flt-recs">
      <div class="flt-recs__inner">
        
        <div class="flt-recs__heading-wrap flt-reveal">
          <div class="flt-recs__eyebrow">Handpicked for you</div>
          <h2 class="flt-recs__title">You May Also Like</h2>
        </div>

        <div class="flt-recs__grid">
          {% for product in recommendations.products %}
            <div class="flt-reveal" style="transition-delay: {{ forloop.index0 | times: 0.1 }}s">
              {% render 'flt-product-card-1', product: product %}
            </div>
          {% endfor %}
        </div>
        
      </div>
    </section>

    <script>
      (function() {
        // Re-initialize the reveal observer for dynamically loaded content
        var scope = document.querySelector('#flt-product-recommendations-{{ section.id }}');
        var reveals = scope.querySelectorAll('.flt-reveal');
        
        if ('IntersectionObserver' in window) {
          var obs = new IntersectionObserver(function(entries) {
            entries.forEach(function(e) {
              if (e.isIntersecting) {
                e.target.classList.add('in-view');
                obs.unobserve(e.target);
              }
            });
          }, { threshold: 0.1 });
          reveals.forEach(function(el) { obs.observe(el); });
        } else {
          reveals.forEach(function(el) { el.classList.add('in-view'); });
        }
      })();
    </script>
  {% else %}
    
    <div style="text-align:center; color:#888; margin-top:20px;">
      No related products found.
    </div>

  {% endif %}
</product-recommendations>

{% schema %}
{
  "name": "FLT Related Products",
  "tag": "div",
  "class": "flt-recs-section",
  "limit": 1,
  "presets": [
    {
      "name": "FLT Related Products"
    }
  ]
}
{% endschema %}