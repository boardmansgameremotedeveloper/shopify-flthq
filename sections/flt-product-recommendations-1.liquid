{% comment %}
  sections/flt-product-recommendations-1.liquid
  Updated to include FLT Scroll Reveal and matching grid layout.
{% endcomment %}

<script src="{{ 'product-recommendations.js' | asset_url }}" defer="defer"></script>

<style>
  .flt-recs {
    padding: 80px 40px; /* Increased padding to match homepage feel */
    background: #fff;
    position: relative;
  }

  .flt-recs__inner {
    max-width: 1300px;
    margin: 0 auto;
  }

  .flt-recs__heading-wrap {
    text-align: center; /* Centered to match homepage style */
    margin-bottom: 48px;
  }

  .flt-recs__eyebrow {
    font-family: var(--body);
    font-size: 13px;
    color: #64748B;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    margin-bottom: 12px;
    font-weight: 600;
  }

  .flt-recs__title {
    font-family: var(--head);
    font-size: clamp(32px, 4vw, 48px);
    color: #0B2545;
    margin: 0;
    line-height: 1;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .flt-recs__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 28px;
  }

  /* Scroll reveal support for the recommendations */
  .flt-recs .flt-reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .flt-recs .flt-reveal.in-view {
    opacity: 1;
    transform: translateY(0);
  }

  /* Product card image-wrap rounding scoped to this section */
  .flt-recs .flt-product-card__image-wrap {
    border-radius: 12px;
    overflow: hidden;
  }

  /* Skeleton loading cards */
  .flt-recs__skeleton-item {
    height: 320px;
    background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: flt-shimmer 1.4s infinite;
    border-radius: 20px;
  }
  @keyframes flt-shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  @media (max-width: 768px) {
    .flt-recs { padding: 60px 20px; }
    .flt-recs__grid {
      grid-template-columns: 1fr; /* Single column on mobile like homepage */
      gap: 24px;
    }
  }
</style>

<product-recommendations
  id="flt-product-recommendations-{{ section.id }}"
  class="flt-recs-component"
  data-url="{{ routes.product_recommendations_url }}?limit={{ section.settings.max_products | default: 4 }}"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-intent="related"
  data-recommendations-performed="{{ recommendations.performed }}"
>
  <section class="flt-recs">
    <div class="flt-recs__inner">

      <!-- Heading -->
      <div class="flt-recs__heading-wrap flt-reveal">
        <div class="flt-recs__eyebrow">Handpicked for you</div>
        <h2 class="flt-recs__title">Related Products</h2>
      </div>

      {%- if recommendations.performed -%}
        {%- liquid
          if recommendations.products_count == 0
            assign related_products = collections.all.products | reject: 'id', product.id
          else
            assign related_products = recommendations.products
          endif
        -%}
        {% if related_products != blank %}
          <div class="flt-recs__grid">
            {% for related_product in related_products limit: section.settings.max_products | default: 4 %}
              <div class="flt-reveal" style="transition-delay: {{ forloop.index0 | times: 0.1 }}s">
                {% render 'flt-product-card-1', product: related_product %}
              </div>
            {% endfor %}
          </div>
        {% endif %}
      {%- else -%}
        <div class="flt-recs__grid flt-recs__skeleton">
          {% for i in (1..4) %}<div class="flt-recs__skeleton-item"></div>{% endfor %}
        </div>
      {%- endif -%}

    </div>
  </section>

  <script>
    (function() {
      var scope = document.querySelector('#flt-product-recommendations-{{ section.id }}');
      if (!scope) return;

      var reveals = scope.querySelectorAll('.flt-reveal');
      if ('IntersectionObserver' in window) {
        var obs = new IntersectionObserver(function(entries) {
          entries.forEach(function(e) {
            if (e.isIntersecting) {
              e.target.classList.add('in-view');
              obs.unobserve(e.target);
            }
          });
        }, { threshold: 0.1 });
        reveals.forEach(function(el) { obs.observe(el); });
      } else {
        reveals.forEach(function(el) { el.classList.add('in-view'); });
      }

      /* ── Add to Cart — delegated on outer element (survives innerHTML replacement) ── */
      scope.addEventListener('click', function(e) {
        var btn = e.target.closest('.flt-add-to-cart-btn');
        if (!btn) return;
        var variantId = btn.dataset.variantId;
        if (!variantId) return;
        btn.disabled = true;
        btn.textContent = 'Adding\u2026';
        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ id: Number(variantId), quantity: 1 })
        })
        .then(function(r) { return r.json(); })
        .then(function() {
          btn.textContent = 'Added!';
          setTimeout(function() { btn.textContent = 'Add to Cart'; btn.disabled = false; }, 2000);
        })
        .catch(function() { btn.textContent = 'Error'; btn.disabled = false; });
      });
    })();
  </script>
</product-recommendations>

{% schema %}
{
  "name": "FLT Related Products",
  "tag": "div",
  "class": "flt-recs-section",
  "limit": 1,
  "settings": [
    {
      "type": "range",
      "id": "max_products",
      "label": "Max products",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "FLT Related Products"
    }
  ]
}
{% endschema %}