{% comment %}
  sections/flt-product-recommendations-1.liquid
  FLT Hemp Provisions — Related Products (Product Detail Page)
  Rendered at bottom of templates/product.flthq-product-card.json
  Uses the Horizon <product-recommendations> web component (product-recommendations.js)
  which fetches /recommendations/products?section_id=<id>&product_id=<id> and injects
  the re-rendered section HTML. The recommendations object is available on that second render.
  Cards rendered via flt-product-card-1.liquid — same markup + styles as homepage grid.
  CSS for .flt-product-card lives globally in sections/flt-header-1.liquid.
{% endcomment %}

<script
  src="{{ 'product-recommendations.js' | asset_url }}"
  defer="defer"
></script>

<style>
  .flt-recs {
    padding: 64px 40px;
    background: #fff;
  }

  .flt-recs__inner {
    max-width: 1300px;
    margin: 0 auto;
  }

  .flt-recs__heading {
    font-family: var(--head);
    font-size: clamp(28px, 3.5vw, 44px);
    color: #0B2545;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0 0 40px;
  }

  .flt-recs__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 28px;
  }

  @media (max-width: 768px) {
    .flt-recs {
      padding: 48px 20px;
    }
    .flt-recs__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
  }
</style>

<product-recommendations
  id="flt-product-recommendations-{{ section.id }}"
  class="flt-recs-component"
  data-url="{{ routes.product_recommendations_url }}?limit=4"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
>
  {% if recommendations.performed and recommendations.products_count > 0 %}
    <div class="flt-recs">
      <div class="flt-recs__inner">
        <h3 class="flt-recs__heading">You May Also Like</h3>
        <div class="flt-recs__grid">
          {% for product in recommendations.products limit: 4 %}
            {% render 'flt-product-card-1', product: product %}
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}
</product-recommendations>

{% schema %}
{
  "name": "FLT Related Products",
  "tag": "div",
  "class": "flt-recs-section",
  "limit": 1
}
{% endschema %}
